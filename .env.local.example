# ─── Open-Elevation API ──────────────────────────────────────
# Public endpoint (free, no key required)
NEXT_PUBLIC_ELEVATION_API_URL=https://api.open-elevation.com/api/v1/lookup

# ─── App Config ──────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=TrailNav
